{
  "name": "@rtl-fixer/cli",
  "version": "0.1.0",
  "description": "CLI tool for RTL text fixing",
  "type": "module",
  "bin": {
    "rtl-fix": "./dist/rtl-fix.mjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/rtl-fix.mjs --banner:js='#!/usr/bin/env node'"
  },
  "dependencies": {
    "@rtl-fixer/core": "workspace:*"
  },
  "devDependencies": {
    "esbuild": "latest"
  }
}
