{
  "name": "@rtl-fixer/electron",
  "version": "0.2.0",
  "description": "RTL Fixer desktop application",
  "main": "./out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "pnpm build && electron-builder --linux",
    "pack:appimage": "pnpm build && electron-builder --linux AppImage",
    "pack:deb": "pnpm build && electron-builder --linux deb",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@rtl-fixer/core": "workspace:*",
    "diff": "^8.0.3",
    "framer-motion": "^12.35.1",
    "marked": "^17.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.7.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/diff": "^7.0.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "build": {
    "appId": "com.rfgh.rtl-fixer",
    "productName": "RTL Fixer",
    "files": ["out/**/*"],
    "linux": {
      "target": ["AppImage", "deb", "tar.gz"],
      "category": "Utility"
    }
  }
}
