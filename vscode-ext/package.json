{
  "name": "rtl-fixer",
  "displayName": "RTL Fixer",
  "description": "Fix bidirectional text for Persian-English mixed content",
  "version": "0.1.0",
  "publisher": "refighdev",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Formatters"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rtlFixer.fixDocument",
        "title": "RTL Fixer: Fix Document"
      },
      {
        "command": "rtlFixer.fixSelection",
        "title": "RTL Fixer: Fix Selection"
      },
      {
        "command": "rtlFixer.stripMarks",
        "title": "RTL Fixer: Strip All Marks"
      }
    ],
    "keybindings": [
      {
        "command": "rtlFixer.fixDocument",
        "key": "ctrl+shift+r",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "build": "npx esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node"
  }
}
